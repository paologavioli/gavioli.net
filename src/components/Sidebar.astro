---
interface Props {
  activeCategory?: string;
  categories: { slug: string; label: string; count: number }[];
}
const { activeCategory = '', categories } = Astro.props;

const base = import.meta.env.BASE_URL;
const navLinks = [
  { href: base, label: '/ blog' },
  { href: `${base}about`, label: '/ chi sono' },
];
---

<aside class="sidebar">
  <a href={base} class="brand" aria-label="Torna alla home">
    <div class="avatar" aria-hidden="true">PG</div>
    <h1 class="site-title">gavioli<span class="accent">.net</span></h1>
    <p class="tagline">appassionato di tecnologia · smanettone cronico</p>
  </a>

  <nav aria-label="Navigazione principale">
    {navLinks.map(link => (
      <a href={link.href} class={`nav-link ${Astro.url.pathname === link.href ? 'active' : ''}`}>
        {link.label}
      </a>
    ))}
  </nav>

  <div class="cat-section">
    <p class="section-label">Categorie</p>
    <div class="cat-list">
      <a href={base} class={`cat-row ${!activeCategory ? 'active' : ''}`}>
        <span>tutti</span>
        <span class="cat-count">{categories.reduce((n, c) => n + c.count, 0)}</span>
      </a>
      {categories.map(cat => (
        <a href={`${base}categoria/${cat.slug}`} class={`cat-row ${activeCategory === cat.slug ? 'active' : ''}`}>
          <span>{cat.label}</span>
          <span class="cat-count">{cat.count}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="sidebar-footer">
    <div class="social-links">
      <a href="https://www.linkedin.com/in/pgavioli/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">in</a>
    </div>
    <button onclick="window.toggleTheme()" class="theme-toggle" aria-label="Cambia tema">
      <span class="theme-dot" aria-hidden="true"></span>
      <span data-theme-label>dark</span>
    </button>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 52px 0;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .sidebar::-webkit-scrollbar { display: none; }

  .brand { display: block; margin-bottom: 40px; }

  .avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: var(--accent);
    display: flex; align-items: center; justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500; font-size: 13px;
    letter-spacing: -0.02em;
    color: var(--bg);
    margin-bottom: 18px;
    user-select: none;
  }

  .site-title {
    font-size: 19px; font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }
  .accent { color: var(--accent); }

  .tagline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }

  nav { display: flex; flex-direction: column; gap: 2px; margin-bottom: 32px; }

  .nav-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    padding: 5px 0;
    color: var(--muted);
    transition: color .15s;
  }
  .nav-link:hover, .nav-link.active { color: var(--fg); }

  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 12px;
  }

  .cat-list { display: flex; flex-direction: column; gap: 1px; }

  .cat-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 6px 10px; margin: 0 -10px;
    border-radius: 5px;
    font-size: 14px;
    color: var(--muted);
    transition: all .15s;
    cursor: pointer;
  }
  .cat-row:hover { color: var(--fg); background: var(--surface2); }
  .cat-row.active { color: var(--fg); background: var(--surface2); }

  .cat-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--faint);
  }

  .sidebar-footer {
    margin-top: auto;
    display: flex; align-items: center; justify-content: space-between;
  }

  .social-links {
    display: flex; gap: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }
  .social-links a:hover { color: var(--fg); }

  .theme-toggle {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: transparent; border: none;
    cursor: pointer; padding: 0;
    transition: color .15s;
  }
  .theme-toggle:hover { color: var(--fg); }

  .theme-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .sidebar {
      position: static;
      height: auto;
      width: 100%;
      min-width: 0;
      padding: 20px 0;
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
      overflow: visible;
    }
    .brand { margin-bottom: 0; }
    .tagline { display: none; }
    nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
      margin-bottom: 0;
    }
    .cat-section {
      min-width: 0;
      margin-bottom: 0;
    }
    .section-label { display: none; }
    .cat-list {
      flex-direction: row;
      width: 100%;
      min-width: 0;
      max-width: 100%;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      padding-bottom: 2px;
    }
    .cat-list::-webkit-scrollbar { display: none; }
    .cat-row {
      flex-shrink: 0;
      margin: 0;
      padding: 6px 12px;
      border: 1px solid var(--line);
      white-space: nowrap;
    }
    .cat-count { display: none; }
    .sidebar-footer {
      margin-top: 0;
      padding-top: 14px;
      border-top: 1px solid var(--line);
    }
  }

  @media (max-width: 480px) {
    .sidebar { gap: 12px; }
    nav { gap: 12px; }
  }
</style>
