---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const CATEGORIES = ['sysadmin', 'viaggi', 'note', 'hardware'];
const categories = CATEGORIES.map(slug => ({
  slug, label: slug,
  count: allPosts.filter(p => p.data.category === slug).length,
}));

const lastUpdate = '2025-06-01';
---

<Base title="Privacy Policy — gavioli.net" description="Informativa sulla privacy e sui cookie di gavioli.net">
  <div class="layout">
    <Sidebar categories={categories} />

    <main>
      <article class="prose">
        <h1>Privacy Policy</h1>
        <p class="meta">Ultimo aggiornamento: {lastUpdate}</p>

        <h2>Dati raccolti</h2>
        <p>
          Questo sito <strong>non raccoglie dati personali</strong> degli utenti. Non utilizza
          sistemi di analytics, tracker di terze parti, pixel di tracciamento o cookie
          pubblicitari di alcun tipo.
        </p>

        <h2>Cookie utilizzati</h2>
        <p>Utilizziamo esclusivamente cookie tecnici strettamente necessari:</p>
        <ul>
          <li><strong>theme</strong> — salva la preferenza chiaro/scuro. Nessuna scadenza definita. Non trasmesso a terzi.</li>
          <li><strong>cookie-consent</strong> — registra la tua scelta sul banner cookie. Nessuna scadenza definita. Non trasmesso a terzi.</li>
        </ul>
        <p>
          Questi cookie sono memorizzati nel <code>localStorage</code> del tuo browser e non
          vengono mai inviati a server esterni.
        </p>

        <h2>Font Google Fonts</h2>
        <p>
          Il sito carica font da Google Fonts. Questa operazione comporta una richiesta al
          server di Google, che può registrare il tuo indirizzo IP. Consulta la
          <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">privacy policy di Google</a>
          per i dettagli. Stiamo valutando di hostare i font in locale per eliminare questa dipendenza.
        </p>

        <h2>Hosting</h2>
        <p>
          Il sito è ospitato su GitHub Pages (Microsoft). I log di accesso possono essere
          conservati da GitHub secondo la propria
          <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener">informativa privacy</a>.
        </p>

        <h2>Diritti dell'utente</h2>
        <p>
          Non raccogliendo dati personali, non vi sono dati su cui esercitare i diritti
          previsti dal GDPR (accesso, rettifica, cancellazione, ecc.).
        </p>

        <h2>Modifiche</h2>
        <p>
          Questa informativa può essere aggiornata. La data in cima indica l'ultima modifica.
        </p>
      </article>

      <div class="back-link">
        <a href={import.meta.env.BASE_URL}>← tutti i post</a>
      </div>

      <Footer />
    </main>
  </div>
</Base>

<style>
  .layout {
    max-width: 1060px; margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 248px 1fr;
    gap: 56px; align-items: start;
  }
  main { min-width: 0; padding: 52px 0 80px; }

  .prose { max-width: 680px; }
  .prose h1 {
    font-size: 28px; font-weight: 700;
    letter-spacing: -0.02em; margin-bottom: 8px;
  }
  .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--faint);
    margin-bottom: 40px;
  }
  .prose h2 { font-size: 18px; font-weight: 600; margin: 32px 0 10px; }
  .prose p { margin-bottom: 16px; line-height: 1.7; }
  .prose ul { margin: 0 0 16px 24px; }
  .prose li { margin-bottom: 6px; }
  .prose a { color: var(--accent); text-decoration: underline; }
  .prose strong { font-weight: 600; }
  .prose code {
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: 4px; padding: 1px 6px;
  }

  .back-link {
    margin-top: 48px; padding-top: 32px;
    border-top: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
  }
  .back-link a { color: var(--muted); }
  .back-link a:hover { color: var(--fg); }

  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; gap: 0; padding: 0 20px; }
    main { padding: 24px 0 60px; }
  }
</style>
