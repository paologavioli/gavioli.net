---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const CATEGORIES = ['sysadmin', 'viaggi', 'note', 'hardware'];
const categories = CATEGORIES.map(slug => ({
  slug, label: slug,
  count: allPosts.filter(p => p.data.category === slug).length,
}));

const dateStr = post.data.date.toLocaleDateString('it-IT', { day: '2-digit', month: 'long', year: 'numeric' });
---

<Base title={`${post.data.title} — gavioli.net`} description={post.data.description}>
  <div class="layout">
    <Sidebar categories={categories} activeCategory={post.data.category} />

    <main>
      <article>
        <header class="post-header">
          <div class="post-meta">
            <a href={`${import.meta.env.BASE_URL}categoria/${post.data.category}`} class="cat-badge">{post.data.category}</a>
            <time datetime={post.data.date.toISOString()} class="post-date">{dateStr}</time>
          </div>
          <h1 class="post-title">{post.data.title}</h1>
          <p class="post-desc">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="tags">
              {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>
      </article>

      <div class="back-link">
        <a href={import.meta.env.BASE_URL}>← tutti gli scritti</a>
      </div>

      <Footer />
    </main>
  </div>
</Base>

<style>
  .layout {
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 248px 1fr;
    gap: 56px;
    align-items: start;
  }

  main { min-width: 0; padding: 52px 0 80px; }

  .post-header {
    padding-bottom: 36px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 40px;
  }

  .post-meta {
    display: flex; align-items: center; gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .cat-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 2px 8px;
    transition: background .15s;
  }
  .cat-badge:hover { background: var(--accent-dim); }

  .post-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--faint);
  }

  .post-title {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 12px;
  }

  .post-desc {
    font-size: 17px;
    color: var(--muted);
    max-width: 560px;
    margin-bottom: 16px;
  }

  .tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--faint);
  }

  /* ---- Prose styles ---- */
  .prose { max-width: 680px; }
  .prose :global(h2) {
    font-size: 20px; font-weight: 600;
    letter-spacing: -0.01em;
    margin: 36px 0 12px;
    color: var(--fg);
  }
  .prose :global(h3) {
    font-size: 17px; font-weight: 600;
    margin: 28px 0 8px;
  }
  .prose :global(p) {
    margin-bottom: 18px;
    color: var(--fg);
  }
  .prose :global(ul), .prose :global(ol) {
    margin: 0 0 18px 24px;
  }
  .prose :global(li) { margin-bottom: 6px; }
  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(a:hover) { opacity: .8; }
  .prose :global(strong) { color: var(--fg); font-weight: 600; }
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--line);
    margin: 8px 0 24px;
    display: block;
  }
  .prose :global(em) { font-style: italic; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--line);
    margin: 36px 0;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    margin: 24px 0;
    color: var(--muted);
    font-style: italic;
  }
  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1px 6px;
  }
  .prose :global(pre) {
    background: var(--surface) !important;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 20px 24px;
    overflow-x: auto;
    margin: 0 0 24px;
    font-size: 13px;
    line-height: 1.7;
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
    font-size: 14px;
  }
  .prose :global(th), .prose :global(td) {
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line);
  }
  .prose :global(th) { color: var(--muted); font-weight: 500; }

  .back-link {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
  }
  .back-link a { color: var(--muted); }
  .back-link a:hover { color: var(--fg); }

  @media (max-width: 768px) {
    .layout {
      grid-template-columns: 1fr;
      gap: 0;
      padding: 0 20px;
    }
    main { padding: 24px 0 60px; }
    .post-title { font-size: 22px; }
  }
</style>
