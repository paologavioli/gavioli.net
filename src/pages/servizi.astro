---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const CATEGORIES = ['sysadmin', 'viaggi', 'note', 'hardware'];
const categories = CATEGORIES.map(slug => ({
  slug, label: slug,
  count: allPosts.filter(p => p.data.category === slug).length,
}));

const services = [
  {
    title: 'Networking',
    desc: 'Progettazione e configurazione di reti aziendali: VLAN, routing, firewall, VPN site-to-site e accesso remoto sicuro.',
  },
  {
    title: 'Sistemistica',
    desc: 'Gestione di server Linux e Windows, virtualizzazione, backup e disaster recovery, monitoraggio dell\'infrastruttura.',
  },
  {
    title: 'Sicurezza',
    desc: 'Hardening di reti e sistemi, segmentazione, configurazione di firewall perimetrali, audit e messa in sicurezza di ambienti esistenti.',
  },
  {
    title: 'Consulenza continuativa',
    desc: 'Supporto IT su base periodica per piccole aziende che non hanno bisogno di una figura interna a tempo pieno.',
  },
];
---

<Base title="Servizi — gavioli.net" description="Consulenza IT: networking, sistemistica, sicurezza per piccole e medie aziende.">
  <div class="layout">
    <Sidebar categories={categories} />

    <main>
      <article class="prose">
        <h1>Servizi</h1>
        <p class="intro">
          Consulenza IT su misura per piccole e medie aziende: dalla progettazione
          della rete alla gestione quotidiana dei sistemi.
        </p>

        <div class="services-list">
          {services.map(s => (
            <div class="service">
              <h2>{s.title}</h2>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>

        <h2>Come lavoro</h2>
        <p>
          Parto sempre da un'analisi della situazione esistente, propongo soluzioni
          proporzionate alle reali esigenze (niente over-engineering) e lascio sempre
          documentazione chiara di quello che viene fatto.
        </p>

        <h2>Contatti</h2>
        <p>
          Per una consulenza o un preventivo, scrivimi a
          <a href="mailto:info@gavioli.net">info@gavioli.net</a>.
        </p>
      </article>

      <div class="back-link">
        <a href={import.meta.env.BASE_URL}>← torna al blog</a>
      </div>

      <Footer />
    </main>
  </div>
</Base>

<style>
  .layout {
    max-width: 1060px; margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 248px 1fr;
    gap: 56px; align-items: start;
  }
  main { min-width: 0; padding: 52px 0 80px; }

  .prose { max-width: 680px; }
  .prose h1 {
    font-size: 28px; font-weight: 700;
    letter-spacing: -0.02em; margin-bottom: 8px;
  }
  .intro {
    font-size: 17px; color: var(--muted);
    margin-bottom: 32px;
  }
  .prose h2 { font-size: 18px; font-weight: 600; margin: 32px 0 10px; }
  .prose p { margin-bottom: 16px; line-height: 1.7; }
  .prose a { color: var(--accent); text-decoration: underline; }

  .services-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 8px;
  }
  .service {
    padding: 18px 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .service h2 {
    font-size: 15px; font-weight: 600;
    margin: 0 0 8px;
  }
  .service p {
    font-size: 14px; color: var(--muted);
    margin-bottom: 0;
    line-height: 1.6;
  }

  .back-link {
    margin-top: 48px; padding-top: 32px;
    border-top: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
  }
  .back-link a { color: var(--muted); }
  .back-link a:hover { color: var(--fg); }

  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; gap: 0; padding: 0 20px; }
    main { padding: 24px 0 60px; }
    .services-list { grid-template-columns: 1fr; }
  }
</style>
