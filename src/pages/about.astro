---
import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const CATEGORIES = ['sysadmin', 'viaggi', 'note', 'hardware'];
const categories = CATEGORIES.map(slug => ({
  slug, label: slug,
  count: allPosts.filter(p => p.data.category === slug).length,
}));
---

<Base title="Chi sono — gavioli.net" description="Consulente IT: chi sono, di cosa mi occupo e perché scrivo questo blog.">
  <div class="layout">
    <Sidebar categories={categories} />

    <main>
      <article class="prose">
        <h1>Chi sono</h1>

        <p>
          Sono Paolo. Smanetto con reti, server e
          infrastrutture IT da più di 20 anni e non mi sono ancora stufato — anzi.
          Sono co-fondatore di <strong>Update S.r.l. </strong>, dove ogni giorno aiuto
          aziende a cavarsela con cybersecurity, continuità operativa e trasformazione
          digitale, che detto così suona da slide aziendale ma in pratica vuol dire:
          reti che non cadono, sistemi che non si bloccano e clienti che dormono la notte.
        </p>

        <p>
          Negli anni ho accompagnato parecchie realtà verso cloud, virtualizzazione e
          networking più seri, cercando sempre di tenere insieme sicurezza, efficienza
          e scalabilità senza complicare le cose più del necessario.
        </p>

        <h2>Di cosa mi occupo</h2>
        <ul>
          <li>Progettazione e gestione di data center e reti, anche distribuite su più sedi.</li>
          <li>Consulenza su infrastrutture IT, cybersecurity e disaster recovery.</li>
          <li>Soluzioni su misura — niente template da rivenditore.</li>
          <li>Supporto continuativo e troubleshooting, perché qualcosa si rompe sempre proprio nel weekend.</li>
          <li>Caccia alle tecnologie nuove che servono davvero al business, non solo a fare scena.</li>
        </ul>

        <p>
          L'obiettivo resta semplice: fare le cose bene, spiegarle in modo che si capiscano,
          ed essere quello che richiami quando qualcosa non va — non quello che sparisce dopo la fattura.
        </p>

        <h2>Dove trovarmi</h2>
        <p>
          <a href="https://www.linkedin.com/in/pgavioli/" target="_blank" rel="noopener">LinkedIn</a>.
        </p>
      </article>

      <div class="back-link">
        <a href={import.meta.env.BASE_URL}>← torna al blog</a>
      </div>

      <Footer />
    </main>
  </div>
</Base>

<style>
  .layout {
    max-width: 1060px; margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: 248px 1fr;
    gap: 56px; align-items: start;
  }
  main { min-width: 0; padding: 52px 0 80px; }

  .prose { max-width: 680px; }
  .prose h1 {
    font-size: 28px; font-weight: 700;
    letter-spacing: -0.02em; margin-bottom: 24px;
  }
  .prose h2 { font-size: 18px; font-weight: 600; margin: 32px 0 10px; }
  .prose p { margin-bottom: 16px; line-height: 1.7; }
  .prose ul { margin: 0 0 16px 24px; }
  .prose li { margin-bottom: 6px; line-height: 1.6; }
  .prose a { color: var(--accent); text-decoration: underline; }
  .prose strong { font-weight: 600; }

  .back-link {
    margin-top: 48px; padding-top: 32px;
    border-top: 1px solid var(--line);
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
  }
  .back-link a { color: var(--muted); }
  .back-link a:hover { color: var(--fg); }

  @media (max-width: 768px) {
    .layout { grid-template-columns: 1fr; gap: 0; padding: 0 20px; }
    main { padding: 24px 0 60px; }
  }
</style>
